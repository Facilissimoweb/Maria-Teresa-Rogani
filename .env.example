# GROQ_API_KEY: Required for Groq AI chat API calls.
# Users configure this via the Environment Variables panel in their Vercel dashboard.
GROQ_API_KEY="your_groq_api_key_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP settings for real-time contact form email dispatch
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="facilissimoweb.mc@gmail.com"
SMTP_PASS=""

